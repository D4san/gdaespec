   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from matplotlib.lines import Line2D\n",
    "\n",
    "# --- Config ---\n",
    "csv_path = r\"POSEIDON_output\\Trappist-1e\\retrievals\\retrieved_gases_recovered_minmax.csv\"\n",
    "\n",
    "PALETTE = {\n",
    "    \"uncontam\": \"#264653\",  # ink\n",
    "    \"contam\":   \"#2A9D8F\",  # teal\n",
    "    \"recon\":    \"#F4A261\",  # apricot\n",
    "    \"recon_sigma\": \"#E76F51\",  # red-orange\n",
    "}""}\n",
    "LEGEND_LABELS = {\n",
    "    \"uncontam\": \"Chem. Retrieval\",\n",
    "    \"contam\":   \"(Stellar Contam. + Chem.)\",\n",
    "    \"recon\":    \"AE & (Stellar Contam. + Chem.)\",\n",
    "    \"recon_sigma\": \"AE σ & (Stellar Contam. + Chem.)\",\n",
    "}""}\n",
    "FAM_OFFSETS = {\"contam\": -0.2, \"recon\": -0.07, \"recon_sigma\": 0.07, \"uncontam\": +0.2}"
    "ALLOWED = set(PALETTE.keys())\n",
    "\n",
    "EXPECTED = {\"CO2\": -3.0, \"CH4\": -8.0, \"O3\": -8.0, \"H2O\": -8.0}\n",
    "\n",
    "# Marcadores por n_transits (se asignan automáticamente si hay más valores)\n",
    "MARKER_CYCLE = ['o', 's', 'D', '^', 'v', 'P', 'X']  # 10T, 100T, 150T, ...\n",
    "EDGE_COLOR = \"#222222\"\n",
    "\n",
    "\n",
    "\n",
    "# Tipos numéricos\n",
    "for col in [\n",
    "    \"n_transits\",\"spot_fraction\",\"facula_fraction\",\n",
    "    \"log_CO2\",\"log_CO2_min1s\",\"log_CO2_max1s\",\n",
    "    \"log_CH4\",\"log_CH4_min1s\",\"log_CH4_max1s\",\n",
    "    \"log_O3\",\"log_O3_min1s\",\"log_O3_max1s\",\n",
    "    \"log_H2O\",\"log_H2O_min1s\",\"log_H2O_max1s\",\n",
    "]:\n",
    "    if col in df.columns:\n",
    "        df[col] = pd.to_numeric(df[col], errors=\"coerce\")\n",
    "\n",
    "# Etiqueta x = ffac/fspot (categórica)\n",
    "def ratio_label(row):\n",
    "    sf, ff = row.get(\"spot_fraction\", np.nan), row.get(\"facula_fraction\", np.nan)\n",
    "    if pd.notna(sf) and pd.notna(ff):\n",
    "        if sf == 0 and ff == 0: return \"clean\"\n",
    "        if sf == 0:             return \"∞\"\n",
    "        return f\"{ff:.2f}/{sf:.2f}\"\n",
    "    return \"?\"\n",
    "\n",
    "df[\"x_label\"] = df.apply(ratio_label, axis=1)\n",
    "\n",
    "# Orden de x (por ratio numérico), 'clean' primero\n",
    "def numeric_ratio(row):\n",
    "    sf, ff = row.get(\"spot_fraction\", np.nan), row.get(\"facula_fraction\", np.nan)\n",
    "    if pd.isna(sf) or pd.isna(ff): return np.inf\n",
    "    if sf == 0 and ff == 0:        return -np.inf\n",
    "    if sf == 0:                    return np.inf\n",
    "    return ff/sf\n",
    "\n",
    "df[\"_ratio_val\"] = df.apply(numeric_ratio, axis=1)\n",
    "order = (\n",
    "    df[[\"x_label\",\"_ratio_val\"]]\n",
    "    .drop_duplicates()\n",
    "    .sort_values(\"_ratio_val\")\n",
    ")[\"x_label\"].tolist()\n",
    "xpos_map = {lab:i for i,lab in enumerate(order)}\n",
    "df[\"xpos\"] = df[\"x_label\"].map(xpos_map)\n",
    "\n",
    "# Familia (estricta) solo en {contam,recon,recon_sigma,uncontam}\n",
    "def get_family(row):\n",
    "    mt = str(row.get(\"model_type\",\"\")).lower()\n",
    "    mn = str(row.get(\"model_name\",\"\")).lower()\n",
    "    if mt in ALLOWED: return mt\n",
    "    if \"_\" in mn:\n",
    "        pref = mn.split(\"_\",1)[0]\n",
    "        if pref in ALLOWED: return pref\n",
    "    raise ValueError(f\"Familia de modelo desconocida para: {row.get('file','(sin file)')}\")",
    "\n",
    "df[\"model_family\"] = df.apply(get_family, axis=1)\n",
    "\n",
    "# Asignación de marcadores por n_transits\n",
    "nts = sorted([int(x) for x in pd.unique(df[\"n_transits\"].dropna())])\n",
    "marker_map = {nt: MARKER_CYCLE[i % len(MARKER_CYCLE)] for i, nt in enumerate(nts)}\n",
    "\n",
    "# Offsets secundarios por n_transits (pequeños)\n",
    "if len(nts) == 1:\n",
    "    nt_offsets = {nts[0]: 0.0}\n",
    "else:\n",
    "    nt_offsets = {nt: off for nt, off in zip(nts, np.linspace(-0.06, +0.06, len(nts)))}\n",
    "\n",
    "# --- Plot helper ---\n",
    "def plot_gas(ax, gas, data):\n",
    "    y     = f\"log_{gas}\"\n",
    "    y_min = f\"log_{gas}_min1s\"\n",
    "    y_max = f\"log_{gas}_max1s\"\n",
    "\n",
    "    gdf = data[np.isfinite(data[y])]\n",
    "    ax.set_title(gas, pad=8)\n",
    "\n",
    "    # Si no hay datos, mostrar sólo la línea esperada\n",
    "    if gdf.empty:\n",
    "        ax.axhline(EXPECTED[gas], linestyle=\"--\", linewidth=1, color=\"#444\", alpha=0.8)\n",
    "        ax.set_xticks(range(len(order))); ax.set_xticklabels(order, rotation=45, ha=\"right\")\n",
    "        ax.set_ylabel(\"log10 VMR\"); ax.grid(True, axis=\"y\", alpha=0.2)\n",
    "        return\n",
    "\n",
    "    # Group by familia y n_transits: color por familia, marcador por n_transits, offsets combinados\n",
    "    for (fam, nt), sub in gdf.groupby([\"model_family\", \"n_transits\"], dropna=False):\n",
    "        fam = str(fam)\n",
    "        nt  = int(nt) if not pd.isna(nt) else nts[0]\n",
    "        color  = PALETTE[fam]\n",
    "        marker = marker_map[nt]\n",
    "        x = sub[\"xpos\"].values + FAM_OFFSETS[fam] + nt_offsets[nt]\n",
    "        yv = sub[y].values\n",
    "        yerr_low = yv - sub[y_min].values\n",
    "        yerr_up  = sub[y_max].values - yv\n",
    "        yerr = np.vstack([yerr_low, yerr_up])\n",
    "\n",
    "        ax.errorbar(\n",
    "            x, yv, yerr=yerr,\n",
    "            fmt=marker, ms=6, capsize=3, capthick=1, elinewidth=1,\n",
    "            color=color, markerfacecolor=color, markeredgecolor=EDGE_COLOR, markeredgewidth=0.8,\n",
    "            linestyle=\"None\", label=f\"{LEGEND_LABELS[fam]} • {nt}T\",\n",
    "            alpha=0.7  # Añadido alpha para dar transparencia\n",
    "        )\n",
    "\n",
    "    # Línea de referencia (valor esperado)\n",
    "    ax.axhline(EXPECTED[gas], linestyle=\"--\", linewidth=1, color=\"#444\", alpha=0.8)\n",
    "\n",
    "    # Eje x categórico\n",
    "    ax.set_xticks(range(len(order)))\n",
    "    ax.set_xticklabels(order, rotation=45, ha=\"right\")\n",
    "    ax.set_ylabel(\"log10 VMR\")\n",
    "    ax.grid(True, axis=\"y\", alpha=0.2)\n",
    "\n",
    "# --- Figura 2x2, título y leyendas separadas ---\n",
    "fig, axes = plt.subplots(2, 2, figsize=(12, 9))\n",
    "axes = axes.ravel()\n",
    "for ax, gas in zip(axes, [\"CO2\",\"CH4\",\"O3\",\"H2O\"]):\n",
    "    plot_gas(ax, gas, df)\n",
    "\n",
    "# Leyenda 1 (familias) y Leyenda 2 (n_transits)\n",
    "present_fams = [fam for fam in [\"contam\",\"recon\",\"recon_sigma\",\"uncontam\"] if fam in df[\"model_family\"].unique()]"
    "family_handles = [Line2D([0],[0], marker='o', linestyle='None', color=PALETTE[f], label=LEGEND_LABELS[f]) for f in present_fams]\n",
    "transit_handles = [Line2D([0],[0], marker=marker_map[nt], linestyle='None', color=EDGE_COLOR, markerfacecolor=\"none\", markeredgewidth=1.5, label=f\"{nt}T\") for nt in nts]\n",
    "\n",
    "# Reservar espacio arriba y abajo\n",
    "fig.tight_layout(rect=[0.02, 0.08, 1.00, 0.84])  # deja 16% arriba, 8% abajo\n",
    "\n",
    "# Título global\n",
    "fig.suptitle(\"Retrievals vs. contaminación estelar (ffac/fspot)\", y=0.98, fontsize=14)\n",
    "\n",
    "# Leyendas\n",
    "if family_handles:\n",
    "    fig.legend(family_handles, [h.get_label() for h in family_handles],\n",
    "               loc=\"upper center\", bbox_to_anchor=(0.5, 0.90),\n",
    "               ncols=len(family_handles), frameon=False, columnspacing=1.2, handlelength=1.6)\n",
    "\n",
    "if transit_handles:\n",
    "    fig.legend(transit_handles, [h.get_label() for h in transit_handles],\n",
    "               loc=\"lower center\", bbox_to_anchor=(0.5, 0.02),\n",
    "               ncols=len(transit_handles), frameon=False, columnspacing=1.2, handlelength=1.6)\n",
    "\n",
    "plt.show()"
   ]
  }
